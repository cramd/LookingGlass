# ─── VictoriaMetrics ─────────────────────────────────────────────────────────
# Tenant-scoped query endpoint (used for PromQL queries)
VM_CLOUD_URL=http://192.168.0.100:8428

# Bearer token — leave blank for direct VictoriaMetrics without auth
VM_CLOUD_TOKEN=

# Direct admin endpoint — used for /api/v1/status/tsdb and /metrics scraping
# Bypasses vmauth; set to same value as VM_CLOUD_URL if you don't use vmauth
VM_DIRECT_URL=http://192.168.0.100:8428

# ─── VictoriaLogs ────────────────────────────────────────────────────────────
# Log query endpoint (backend) AND base URL for frontend deep-links into vmui
VICTORIALOGS_URL=http://192.168.0.100:9428

# ─── vmalert ─────────────────────────────────────────────────────────────────
# Active alerts endpoint
VMALERT_URL=http://192.168.0.100:8880

# ─── Alertmanager ────────────────────────────────────────────────────────────
# Used for creating silences
ALERTMANAGER_URL=http://192.168.0.100:9093

# ─── Alertmanager webhook ────────────────────────────────────────────────────
# Paste your Slack / Discord incoming webhook URL here.
# Slack:   https://hooks.slack.com/services/T.../B.../...
# Discord: https://discord.com/api/webhooks/.../... (append /slack for compat)
WEBHOOK_URL=

# ─── Grafana ─────────────────────────────────────────────────────────────────
# Grafana URL — used for Platform panel deep links in the Dashboard
GRAFANA_URL=http://192.168.0.100:3001

# ─── Tier / feature flags ────────────────────────────────────────────────────
# Controls upsell banners and node visibility limits.  Values: free | pro | enterprise
SAAS_USER_TIER=free

# ─── Ask the Looking Glass (Gemini AI) ───────────────────────────────────────
# Powers the "Ask" troubleshooting button on alerts, logs, and guest panels.
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── Backend ─────────────────────────────────────────────────────────────────
PORT=5000

# ─── Frontend public env vars (prefix: NEXT_PUBLIC_) ─────────────────────────
# These are embedded at build time and exposed to the browser.
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_GRAFANA_URL=http://192.168.0.100:3001
NEXT_PUBLIC_VM_DIRECT_URL=http://192.168.0.100:8428
NEXT_PUBLIC_VICTORIALOGS_URL=http://192.168.0.100:9428
